<!DOCTYPE html>
<html lang="es" class="h-full bg-zinc-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mi Sistema</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    /* PWA */
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0d6efd" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="TiendaNet" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />


    <style>
        body {
        font-family: 'Inter', sans-serif;
        background-color: #fafafa;
        }
        /* Clases utilitarias globales emulando Shadcn para inputs tradicionales */
        .shadcn-input {
        width: 100%;
        border: 1px solid #e4e4e7; /* zinc-200 */
        background-color: #ffffff;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        border-radius: 0.375rem; /* md */
        transition: all 0.2s;
        }

        .shadcn-input:focus {
        outline: 2px solid transparent;
        outline-offset: 2px;
        border-color: #09090b; /* zinc-950 */
        box-shadow: 0 0 0 1px #09090b;
        }
    </style>
</head>
<script>
    if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
    navigator.serviceWorker.register('/sw.js')
    .then(reg => console.log('SW registrado:', reg.scope))
    .catch(err => console.error('SW error:', err));
    });
    }
</script>

<body class="min-h-screen flex flex-col bg-zinc-50/50 text-zinc-950 antialiased">

    <header class="sticky top-0 z-50 w-full border-b border-zinc-200 bg-white/80 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">

            <div class="flex items-center gap-6">
                <a class="flex items-center gap-2 font-semibold text-zinc-900 tracking-tight hover:opacity-90 transition-opacity" asp-controller="Home" asp-action="Index">
                    <i data-lucide="package" class="w-5 h-5 stroke-[2]"></i>
                    <span>MiInventario</span>
                </a>

                @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioNombre")))
                {
                    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-zinc-600">
                        <a class="flex items-center gap-1.5 hover:text-zinc-950 transition-colors" asp-controller="Tienda" asp-action="Index">
                            <i data-lucide="shopping-bag" class="w-4 h-4"></i>Tienda
                        </a>
                        <a class="flex items-center gap-1.5 hover:text-zinc-950 transition-colors" asp-controller="Reportes" asp-action="Ventas">
                            <i data-lucide="bar-chart-3" class="w-4 h-4"></i>Reportes
                        </a>
                        <a class="flex items-center gap-1.5 hover:text-zinc-950 transition-colors" asp-controller="Home" asp-action="Index">
                            <i data-lucide="home" class="w-4 h-4"></i>Inicio
                        </a>
                        <a class="flex items-center gap-1.5 hover:text-zinc-950 transition-colors" asp-controller="ProductosView" asp-action="Index">
                            <i data-lucide="boxes" class="w-4 h-4"></i>Productos
                        </a>
                    </nav>
                }
            </div>

            <div class="flex items-center gap-4 text-sm font-medium">
                @{
                    var usuarioNombre = Context.Session.GetString("UsuarioNombre");
                }
                @if (!string.IsNullOrEmpty(usuarioNombre))
                {
                    <div class="flex items-center gap-4">
                        <span class="inline-flex items-center gap-1.5 text-zinc-700 bg-zinc-100 px-2.5 py-1 rounded-md text-xs font-medium">
                            <i data-lucide="user" class="w-3.5 h-3.5"></i>
                            @usuarioNombre
                        </span>
                        <a class="inline-flex items-center gap-1.5 text-zinc-500 hover:text-red-600 transition-colors" asp-controller="Account" asp-action="Logout">
                            <i data-lucide="log-out" class="w-4 h-4"></i>
                            <span class="hidden sm:inline">Cerrar Sesión</span>
                        </a>
                    </div>
                }
                else
                {
                    <div class="flex items-center gap-2">
                        <a class="px-3 py-1.5 text-zinc-600 hover:text-zinc-950 transition-colors" asp-controller="Account" asp-action="Login">
                            Iniciar Sesión
                        </a>
                        <a class="px-3 py-1.5 bg-zinc-950 text-white rounded-md hover:bg-zinc-800 transition-colors shadow-sm" asp-controller="Account" asp-action="Register">
                            Registrarse
                        </a>
                    </div>
                }
            </div>
        </div>
    </header>

    <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8" role="main">
        @RenderBody()
    </main>

    <footer class="border-t border-zinc-200 bg-white py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-zinc-500">
            <div>
                © @DateTime.Now.Year - <span class="font-medium text-zinc-700">MiInventario</span> | Sistema de Gestión Premium
            </div>
            <div class="flex gap-4">
                <a asp-controller="Home" asp-action="Privacy" class="hover:underline">Privacidad</a>
                <span>Soporte</span>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
        if (typeof lucide !== 'undefined') {
        lucide.createIcons();
        }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>