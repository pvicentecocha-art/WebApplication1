@model LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiInventario</title>

    <!-- Tailwind CSS (Para control total del motor estético Shadcn) -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Configuración e inyección de estilos extendidos para Shadcn UI -->
    <script>
        tailwind.config = {
        theme: {
        extend: {
        fontFamily: {
        sans: ['Inter', 'sans-serif'],
        }
        }
        }
        }
    </script>

    <!-- Tipografía Inter & Script de Iconos Lucide -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        /* Estilos base para inputs estilo Shadcn UI */
        .shadcn-input {
        width: 100%;
        height: 2.5rem;
        border-radius: 0.375rem;
        border: 1px solid #e4e4e7; /* zinc-200 */
        background-color: #ffffff;
        padding-left: 0.75rem;
        padding-right: 0.75rem;
        font-size: 0.875rem;
        transition: all 0.2s;
        }

        .shadcn-input:focus {
        outline: none;
        border-color: #09090b; /* zinc-950 */
        box-shadow: 0 0 0 1px #09090b;
        }

        .shadcn-input::placeholder {
        color: #a1a1aa; /* zinc-400 */
        }
    </style>
</head>
<body class="min-h-screen bg-zinc-50 flex items-center justify-center p-4 antialiased selection:bg-zinc-950 selection:text-white">

    <!-- Tarjeta Principal (Shadcn Login Card) -->
    <div class="bg-white border border-zinc-200 rounded-xl shadow-sm max-w-md w-full overflow-hidden transition-all duration-300">

        <!-- Encabezado de Identidad -->
        <div class="p-6 md:p-8 text-center border-b border-zinc-100 bg-zinc-50/50">
            <div class="inline-flex p-3 bg-white border border-zinc-200 rounded-xl text-zinc-950 mb-3 shadow-sm">
                <i data-lucide="package" class="w-6 h-6 stroke-[1.5]"></i>
            </div>
            <h2 class="text-2xl font-bold tracking-tight text-zinc-900">MiInventario</h2>
            <p class="text-xs text-zinc-500 mt-1">Ingresa tus credenciales para acceder al panel de control.</p>
        </div>

        <!-- Cuerpo del Formulario de Acceso -->
        <div class="p-6 md:p-8 space-y-5">

            <!-- Mensaje de Éxito Flujo Externo (TempData) -->
            @if (TempData["Mensaje"] != null)
            {
                <div class="flex items-center gap-2 p-3 text-xs font-medium bg-emerald-50 text-emerald-800 border border-emerald-200 rounded-lg shadow-sm">
                    <i data-lucide="check-circle" class="w-4 h-4 text-emerald-600 shrink-0"></i>
                    <span>@TempData["Mensaje"]</span>
                </div>
            }

            <form asp-action="Login" method="post" class="space-y-4">

                <!-- Alerta de Errores de Validación de Modelo -->
                <div asp-validation-summary="ModelOnly" class="text-xs font-medium text-red-700 bg-red-50 border border-red-200 rounded-lg empty:hidden p-3 space-y-1"></div>

                <!-- Campo: Correo Electrónico -->
                <div class="space-y-1.5">
                    <label class="text-xs font-semibold tracking-tight text-zinc-800 flex items-center gap-1.5">
                        <i data-lucide="mail" class="w-3.5 h-3.5 text-zinc-400 stroke-[1.5]"></i>
                        Correo Electrónico
                    </label>
                    <input asp-for="Email" type="email" class="shadcn-input text-zinc-900" placeholder="nombre@empresa.com" required autocomplete="email" />
                    <span asp-validation-for="Email" class="text-xs font-medium text-red-600 block mt-1"></span>
                </div>

                <!-- Campo: Contraseña -->
                <div class="space-y-1.5">
                    <label class="text-xs font-semibold tracking-tight text-zinc-800 flex items-center gap-1.5">
                        <i data-lucide="lock" class="w-3.5 h-3.5 text-zinc-400 stroke-[1.5]"></i>
                        Contraseña
                    </label>
                    <input asp-for="Password" type="password" class="shadcn-input text-zinc-900" placeholder="••••••••" required autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-xs font-medium text-red-600 block mt-1"></span>
                </div>

                <!-- Control Checkbox Recordar Sesión -->
                <div class="flex items-center gap-2 pt-1">
                    <input asp-for="RememberMe" type="checkbox" class="h-4 w-4 rounded border-zinc-300 text-zinc-950 focus:ring-zinc-950 cursor-pointer accent-zinc-950" />
                    <label asp-for="RememberMe" class="text-xs font-medium text-zinc-600 cursor-pointer select-none">
                        Recordarme en este equipo
                    </label>
                </div>

                <!-- Botón de Envío Principal -->
                <button type="submit" class="w-full inline-flex items-center justify-center gap-2 rounded-md text-sm font-medium transition-all bg-zinc-950 text-white hover:bg-zinc-800 h-10 px-4 shadow shadow-zinc-950/10 active:scale-[0.99] tracking-tight mt-2">
                    <i data-lucide="log-in" class="w-4 h-4 stroke-[1.5]"></i>
                    Iniciar Sesión
                </button>
            </form>

            <!-- Enlace Alternativo de Registro -->
            <div class="text-center pt-4 border-t border-zinc-100">
                <a asp-action="Register" class="inline-flex items-center gap-1 text-xs font-medium text-zinc-500 hover:text-zinc-950 transition-colors">
                    <i data-lucide="user-plus" class="w-3.5 h-3.5 stroke-[1.5]"></i>
                    ¿No tienes cuenta? Regístrate aquí
                </a>
            </div>
        </div>
    </div>

    <!-- Scripts de validación en cliente (Mantenemos jQuery e infraestructuras nativas de ASP.NET) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>

    <!-- Inicializador de iconos Lucide -->
    <script>
        lucide.createIcons();
    </script>
</body>
</html>