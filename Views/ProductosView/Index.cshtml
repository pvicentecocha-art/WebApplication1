@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="max-w-7xl mx-auto px-4 py-10 antialiased">

    <!-- NOTIFICACIONES TOAST / ALERT SECTOR -->
    @if (TempData["Mensaje"] != null)
    {
        <div id="shadcn-alert" class="mb-6 flex items-center justify-between p-4 text-sm font-medium bg-emerald-50 text-emerald-800 border border-emerald-200 rounded-lg shadow-sm">
            <div class="flex items-center gap-2">
                <i data-lucide="check-circle" class="w-4 h-4 text-emerald-600 stroke-[2]"></i>
                <span>@TempData["Mensaje"]</span>
            </div>
            <button type="button" onclick="document.getElementById('shadcn-alert').remove()" class="text-emerald-500 hover:text-emerald-700 transition-colors p-1 rounded-md hover:bg-emerald-100/50">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
    }

    <!-- CABECERA DE PANEL (Dashboard Header) -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8 pb-5 border-b border-zinc-200">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-zinc-900 flex items-center gap-2.5">
                <i data-lucide="package" class="w-8 h-8 stroke-[1.5] text-zinc-950"></i>
                Mi Inventario
            </h1>
            <p class="text-sm text-zinc-500 mt-1 flex items-center gap-1.5">
                <i data-lucide="database" class="w-3.5 h-3.5 stroke-[1.5]"></i>
                Total registrado: <span class="font-semibold text-zinc-900">@(Model != null ? Model.Count() : 0) productos</span>
            </p>
        </div>

        <a asp-action="Create" class="inline-flex items-center justify-center gap-1.5 rounded-md text-sm font-medium transition-all bg-zinc-950 text-white hover:bg-zinc-800 h-10 px-4 shadow shadow-zinc-950/10 active:scale-[0.98] tracking-tight">
            <i data-lucide="plus-circle" class="w-4 h-4 stroke-[1.5]"></i>
            Nuevo Producto
        </a>
    </div>

    <!-- CONTENEDOR PRINCIPAL DE TABLA -->
    <div class="bg-white rounded-xl border border-zinc-200 shadow-sm overflow-hidden">

        @if (Model == null || !Model.Any())
        {
            <!-- ESTADO VACÍO (Empty State) -->
            <div class="flex flex-col items-center justify-center p-16 text-center">
                <div class="p-4 bg-zinc-50 rounded-full text-zinc-400 mb-4 border border-zinc-100">
                    <i data-lucide="inbox" class="w-12 h-12 stroke-[1]"></i>
                </div>
                <h3 class="text-lg font-semibold text-zinc-900 tracking-tight">No hay productos en almacén</h3>
                <p class="text-sm text-zinc-500 max-w-xs mt-1 mb-6">El catálogo está limpio. Comienza registrando tu primer artículo comercial.</p>
                <a asp-action="Create" class="inline-flex items-center justify-center gap-1.5 rounded-md text-sm font-medium transition-all bg-zinc-950 text-white hover:bg-zinc-800 h-9 px-4 shadow shadow-zinc-950/10">
                    <i data-lucide="plus-circle" class="w-4 h-4"></i>
                    Agregar Producto
                </a>
            </div>
        }
        else
        {
            <!-- DATA TABLE -->
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse whitespace-nowrap">
                    <thead>
                        <tr class="border-b border-zinc-200 text-zinc-500 text-[11px] font-semibold uppercase tracking-wider bg-zinc-50/70">
                            <th class="py-3.5 px-4 w-16">ID</th>
                            <th class="py-3.5 px-4">Nombre</th>
                            <th class="py-3.5 px-4 hidden md:table-cell max-w-[300px] truncate">Descripción</th>
                            <th class="py-3.5 px-4 text-center w-32">Stock</th>
                            <th class="py-3.5 px-4 text-right w-36">Precio</th>
                            <th class="py-3.5 px-4 text-center w-28">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-zinc-100 text-sm text-zinc-900">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-zinc-50/40 transition-colors">
                                <td class="py-4 px-4 font-mono text-xs font-semibold text-zinc-400">
                                    #@item.Id
                                </td>
                                <td class="py-4 px-4 font-medium text-zinc-900 tracking-tight">
                                    @item.Nombre
                                </td>
                                <td class="py-4 px-4 text-zinc-500 text-xs hidden md:table-cell max-w-[300px] truncate">
                                    @(item.Descripcion?.Length > 60 ? item.Descripcion.Substring(0, 60) + "..." : item.Descripcion ?? "—")
                                </td>
                                <td class="py-4 px-4 text-center">
                                    @if (item.Cantidad == 0)
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 text-[10px] font-semibold bg-red-50 text-red-700 border border-red-200 rounded">
                                            <span class="w-1 h-1 rounded-full bg-red-500"></span> Sin stock
                                        </span>
                                    }
                                    else if (item.Cantidad < 5)
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 text-[10px] font-semibold bg-amber-50 text-amber-700 border border-amber-200 rounded">
                                            <span class="w-1 h-1 rounded-full bg-amber-500"></span> @item.Cantidad uds
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 text-[10px] font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200 rounded">
                                            <span class="w-1 h-1 rounded-full bg-emerald-500"></span> @item.Cantidad uds
                                        </span>
                                    }
                                </td>
                                <td class="py-4 px-4 text-right font-bold text-zinc-950 tracking-tight">
                                    @item.Precio.ToString("C")
                                </td>
                                <td class="py-4 px-4 text-center">
                                    <div class="inline-flex items-center border border-zinc-200 rounded-md bg-white shadow-sm overflow-hidden h-8">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="px-2.5 h-full text-zinc-500 hover:text-zinc-900 hover:bg-zinc-50 transition-colors flex items-center justify-center border-r border-zinc-100" title="Ver detalles">
                                            <i data-lucide="eye" class="w-3.5 h-3.5 stroke-[1.75]"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="px-2.5 h-full text-zinc-500 hover:text-amber-600 hover:bg-amber-50 transition-colors flex items-center justify-center border-r border-zinc-100" title="Editar">
                                            <i data-lucide="edit-2" class="w-3.5 h-3.5 stroke-[1.75]"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="px-2.5 h-full text-zinc-400 hover:text-red-600 hover:bg-red-50 transition-colors flex items-center justify-center" title="Eliminar">
                                            <i data-lucide="trash-2" class="w-3.5 h-3.5 stroke-[1.75]"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<script>
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
</script>