@model LOGIN.Models.Producto

@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="max-w-xl mx-auto px-4 py-12 antialiased">
    <!-- Contenedor Principal (Shadcn Card Component) -->
    <div class="bg-white rounded-xl border border-zinc-200 shadow-sm overflow-hidden">

        <!-- Encabezado del Formulario (Card Header) -->
        <div class="p-6 border-b border-zinc-100 bg-zinc-50/50 text-center">
            <div class="inline-flex p-3 bg-zinc-100 border border-zinc-200 rounded-full text-zinc-950 mb-3">
                <i data-lucide="plus-circle" class="w-6 h-6 stroke-[1.5]"></i>
            </div>
            <h2 class="text-2xl font-bold tracking-tight text-zinc-900">Crear Producto</h2>
            <p class="text-xs text-zinc-500 mt-1">Completa los campos detallados abajo para dar de alta el artículo en el inventario.</p>
        </div>

        <!-- Cuerpo del Formulario (Card Content) -->
        <form asp-action="Create" class="p-6 space-y-5">

            <!-- Resumen de Errores Estilo Callout Destructive de Shadcn -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="text-xs font-medium bg-red-50 text-red-700 border border-red-200 rounded-lg p-3.5 space-y-1"></div>
            }

            <!-- Campo: Nombre -->
            <div class="space-y-1.5">
                <label asp-for="Nombre" class="text-sm font-semibold tracking-tight text-zinc-800 flex items-center gap-1.5">
                    <i data-lucide="tag" class="w-4 h-4 text-zinc-400 stroke-[1.5]"></i>
                    Nombre del producto <span class="text-red-500">*</span>
                </label>
                <input asp-for="Nombre" class="shadcn-input shadow-sm placeholder-zinc-400 text-zinc-900" placeholder="Ej. Laptop Gamer Slim" required />
                <span asp-validation-for="Nombre" class="text-xs font-medium text-red-600 block mt-1"></span>
            </div>

            <!-- Campo: Descripción -->
            <div class="space-y-1.5">
                <label asp-for="Descripcion" class="text-sm font-semibold tracking-tight text-zinc-800 flex items-center gap-1.5">
                    <i data-lucide="align-left" class="w-4 h-4 text-zinc-400 stroke-[1.5]"></i>
                    Descripción
                </label>
                <textarea asp-for="Descripcion" rows="3" class="shadcn-input shadow-sm placeholder-zinc-400 text-zinc-900 min-h-[80px] py-2 resize-none" placeholder="Especificaciones técnicas, detalles de materiales o notas opcionales..."></textarea>
                <span asp-validation-for="Descripcion" class="text-xs font-medium text-red-600 block mt-1"></span>
            </div>

            <!-- Fila Rejilla de Dos Columnas: Cantidad y Precio -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Campo: Cantidad (Stock) -->
                <div class="space-y-1.5">
                    <label asp-for="Cantidad" class="text-sm font-semibold tracking-tight text-zinc-800 flex items-center gap-1.5">
                        <i data-lucide="package" class="w-4 h-4 text-zinc-400 stroke-[1.5]"></i>
                        Cantidad inicial <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Cantidad" type="number" min="0" class="shadcn-input shadow-sm placeholder-zinc-400 text-zinc-900" placeholder="0" required />
                    <span asp-validation-for="Cantidad" class="text-xs font-medium text-red-600 block mt-1"></span>
                </div>

                <!-- Campo: Precio -->
                <div class="space-y-1.5">
                    <label asp-for="Precio" class="text-sm font-semibold tracking-tight text-zinc-800 flex items-center gap-1.5">
                        <i data-lucide="dollar-sign" class="w-4 h-4 text-zinc-400 stroke-[1.5]"></i>
                        Precio unitario <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <input asp-for="Precio" type="number" step="0.01" min="0.01" class="shadcn-input shadow-sm placeholder-zinc-400 text-zinc-900 pl-7" placeholder="0.00" required />
                        <!-- Indicador monetario integrado fijo -->
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-xs font-medium text-zinc-400 pointer-events-none">$</span>
                    </div>
                    <span asp-validation-for="Precio" class="text-xs font-medium text-red-600 block mt-1"></span>
                </div>
            </div>

            <!-- Línea separadora sutil -->
            <div class="border-t border-zinc-100 my-2 pt-2"></div>

            <!-- Bloque de Acciones Inferiores (Card Footer) -->
            <div class="flex items-center justify-end gap-3">
                <a asp-action="Index" class="inline-flex items-center justify-center gap-1.5 rounded-md text-sm font-medium transition-all border border-zinc-200 bg-white text-zinc-700 hover:bg-zinc-50 hover:text-zinc-900 h-10 px-4 active:scale-[0.99]">
                    <i data-lucide="arrow-left" class="w-4 h-4 stroke-[1.5]"></i>
                    Cancelar
                </a>
                <button type="submit" class="inline-flex items-center justify-center gap-1.5 rounded-md text-sm font-medium transition-all bg-zinc-950 text-white hover:bg-zinc-800 h-10 px-5 shadow shadow-zinc-950/10 active:scale-[0.99] tracking-tight">
                    <i data-lucide="save" class="w-4 h-4 stroke-[1.5]"></i>
                    Guardar Producto
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <!-- Mantiene los scripts de validación en tiempo real del lado del cliente de ASP.NET -->
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- Renderizado local de iconos vectoriales de Lucide -->
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    </script>
}