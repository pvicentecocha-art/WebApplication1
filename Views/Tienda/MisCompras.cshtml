@model List<LOGIN.Models.Pedido>

@{
    ViewData["Title"] = "Mis Compras";
}

<div class="max-w-5xl mx-auto px-4 py-10 antialiased">

    <!-- ENCABEZADO DE PÁGINA -->
    <div class="mb-8 border-b border-zinc-200 pb-5">
        <h1 class="text-3xl font-bold tracking-tight text-zinc-900 flex items-center gap-2.5">
            <i data-lucide="history" class="w-8 h-8 stroke-[1.5] text-zinc-950"></i>
            Mis Compras
        </h1>
        <p class="text-sm text-zinc-500 mt-1">Consulta el historial detallado, estado de envío y comprobantes de tus órdenes.</p>
    </div>

    @if (!Model.Any())
    {
        <!-- ESTADO VACÍO (Empty State) -->
        <div class="flex flex-col items-center justify-center border border-dashed border-zinc-200 rounded-xl p-16 text-center bg-white shadow-sm max-w-2xl mx-auto mt-4">
            <div class="p-4 bg-zinc-50 rounded-full text-zinc-400 mb-4 border border-zinc-100">
                <i data-lucide="receipt" class="w-12 h-12 stroke-[1]"></i>
            </div>
            <h3 class="text-lg font-semibold text-zinc-900 tracking-tight">No has realizado compras aún</h3>
            <p class="text-sm text-zinc-500 max-w-xs mt-1 mb-6">Tus pedidos confirmados aparecerán organizados en esta sección.</p>
            <a asp-action="Index" class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-medium transition-all bg-zinc-950 text-white hover:bg-zinc-800 h-10 px-5 shadow shadow-zinc-950/10 active:scale-[0.98]">
                <i data-lucide="shopping-bag" class="w-4 h-4"></i>
                Comenzar a comprar
            </a>
        </div>
    }
    else
    {
        <div class="space-y-6">
            @foreach (var pedido in Model)
            {
                <!-- TARJETA DE PEDIDO INDIVIDUAL (Shadcn Card Component) -->
                <div class="bg-white rounded-xl border border-zinc-200 shadow-sm overflow-hidden transition-all duration-200 hover:border-zinc-300">

                    <!-- Encabezado del Pedido -->
                    <div class="px-6 py-4 bg-zinc-50/70 border-b border-zinc-200 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                        <div class="flex items-center gap-3 flex-wrap">
                            <span class="font-semibold text-zinc-900 text-sm tracking-tight">Pedido #@pedido.Id</span>

                            <!-- Badges Estilizados Condicionales -->
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium border tracking-tight @(pedido.Estado.ToString() switch
                                  {
                                      "Confirmado" => "bg-emerald-50 text-emerald-700 border-emerald-200",
                                      "Entregado" => "bg-blue-50 text-blue-700 border-blue-200",
                                      "Cancelado" => "bg-red-50 text-red-700 border-red-200",
                                      _ => "bg-zinc-100 text-zinc-700 border-zinc-200"
                                  })">
                                @pedido.Estado
                            </span>
                        </div>
                        <div class="flex items-center gap-1.5 text-xs text-zinc-500 font-medium">
                            <i data-lucide="calendar" class="w-3.5 h-3.5 stroke-[1.5]"></i>
                            <span>@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    </div>

                    <!-- Cuerpo de la Tarjeta (Grid de Distribución) -->
                    <div class="p-6">
                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

                            <!-- Tabla de Detalles (8/12 columnas) -->
                            <div class="lg:col-span-8 overflow-x-auto">
                                <table class="w-full text-left border-collapse">
                                    <thead>
                                        <tr class="border-b border-zinc-200 text-zinc-500 text-[11px] font-semibold uppercase tracking-wider">
                                            <th class="pb-2 px-1">Producto</th>
                                            <th class="pb-2 px-1 text-center">Cantidad</th>
                                            <th class="pb-2 px-1 text-right">Precio</th>
                                            <th class="pb-2 px-1 text-right">Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-zinc-100 text-xs text-zinc-700">
                                        @foreach (var detalle in pedido.Detalles!)
                                        {
                                            <tr class="hover:bg-zinc-50/30 transition-colors">
                                                <td class="py-3 px-1 font-medium text-zinc-900">@detalle.Producto?.Nombre</td>
                                                <td class="py-3 px-1 text-center font-normal text-zinc-500">@detalle.Cantidad</td>
                                                <td class="py-3 px-1 text-right font-normal text-zinc-500">@detalle.PrecioUnitario.ToString("C")</td>
                                                <td class="py-3 px-1 text-right font-semibold text-zinc-900">@detalle.Subtotal.ToString("C")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- Caja Lateral de Datos de Entrega (4/12 columnas) -->
                            <div class="lg:col-span-4 bg-zinc-50 border border-zinc-200 rounded-lg p-4 space-y-3 text-xs">
                                <div class="flex justify-between items-center border-b border-zinc-200/60 pb-2">
                                    <span class="text-zinc-500 font-medium">Monto Total</span>
                                    <span class="text-base font-bold text-zinc-950 tracking-tight">@pedido.Total.ToString("C")</span>
                                </div>
                                <div class="space-y-1">
                                    <span class="text-zinc-400 block font-medium">Dirección de Envío</span>
                                    <span class="text-zinc-800 block leading-normal">@pedido.DireccionEnvio</span>
                                </div>
                                <div class="space-y-1 pt-1">
                                    <span class="text-zinc-400 block font-medium">Número de Referencia</span>
                                    <span class="text-zinc-700 block font-mono bg-white border border-zinc-200 rounded px-1.5 py-0.5 w-max">
                                        @pedido.NumeroReferencia
                                    </span>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            }
        </div>
    }
</div>

<!-- Activador de Iconos Lucide -->
<script>
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
</script>