@{
    ViewData["Title"] = "Dashboard";
}

<div class="max-w-4xl mx-auto px-4 py-16 antialiased">
    <div class="row justify-content-center">
        <!-- Contenedor Principal Estilo Shadcn Card -->
        <div class="bg-white rounded-xl border border-zinc-200 shadow-sm p-8 md:p-12 text-center relative overflow-hidden">

            <!-- Icono de Estado de Autenticación Premium -->
            <div class="mb-6 inline-flex items-center justify-center w-16 h-16 bg-zinc-50 border border-zinc-200 rounded-full text-zinc-950 shadow-inner/5">
                <i data-lucide="shield-check" class="w-8 h-8 stroke-[1.5]"></i>
            </div>

            <!-- Título Principal de Bienvenida -->
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 mb-3">
                ¡Bienvenido, @ViewBag.NombreUsuario!
            </h1>

            <!-- Subtítulo Descriptor Desaturado -->
            <p class="text-sm md:text-base text-zinc-500 max-w-md mx-auto mb-10 leading-relaxed">
                Has iniciado sesión correctamente. Desde aquí puedes administrar el catálogo de inventarios o gestionar tu sesión actual.
            </p>

            <!-- Rejilla de Accesos Directos (Grid de 2 Columnas) -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">

                <!-- Tarjeta 1: Gestión de Productos -->
                <div class="p-5 border border-zinc-200 rounded-xl bg-white text-left flex flex-col justify-between transition-all hover:border-zinc-300 hover:shadow-sm group">
                    <div>
                        <div class="text-zinc-400 group-hover:text-zinc-900 transition-colors mb-3">
                            <i data-lucide="layout-grid" class="w-6 h-6 stroke-[1.5]"></i>
                        </div>
                        <h3 class="text-sm font-semibold text-zinc-900 tracking-tight mb-1">Gestión de Productos</h3>
                        <p class="text-xs text-zinc-500 leading-normal">Administra e inspecciona el stock de tu inventario de forma centralizada.</p>
                    </div>
                    <a asp-controller="ProductosView" asp-action="Index" class="inline-flex items-center justify-center gap-1.5 rounded-md text-xs font-medium transition-all bg-zinc-950 text-white hover:bg-zinc-800 h-8 px-3 shadow shadow-zinc-950/10 active:scale-[0.98] mt-4 w-full sm:w-max">
                        <span>Ver Productos</span>
                        <i data-lucide="arrow-right" class="w-3.5 h-3.5 stroke-[2]"></i>
                    </a>
                </div>

                <!-- Tarjeta 2: Mi Cuenta / Cierre de Sesión -->
                <div class="p-5 border border-zinc-200 rounded-xl bg-white text-left flex flex-col justify-between transition-all hover:border-zinc-300 hover:shadow-sm group">
                    <div>
                        <div class="text-zinc-400 group-hover:text-zinc-900 transition-colors mb-3">
                            <i data-lucide="user" class="w-6 h-6 stroke-[1.5]"></i>
                        </div>
                        <h3 class="text-sm font-semibold text-zinc-900 tracking-tight mb-1">Mi Cuenta</h3>
                        <p class="text-xs text-zinc-500 leading-normal">Gestiona tus credenciales de acceso y mantén tu cuenta protegida.</p>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="inline-flex items-center justify-center gap-1.5 rounded-md text-xs font-medium transition-all border border-zinc-200 bg-white text-red-600 hover:bg-red-50 hover:border-red-200 h-8 px-3 active:scale-[0.98] mt-4 w-full sm:w-max">
                        <i data-lucide="log-out" class="w-3.5 h-3.5 stroke-[2]"></i>
                        <span>Cerrar Sesión</span>
                    </a>
                </div>

            </div>

        </div>
    </div>
</div>

<!-- Inicializador local de iconos vectoriales Lucide -->
<script>
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
</script>